    {
      "name": "Auth",
      "item": [
        {
          "name": "Register Primary User",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('Register primary user returns 201', function () {",
                  "  pm.response.to.have.status(201);",
                  "});",
                  "",
                  "const json = pm.response.json();",
                  "pm.collectionVariables.set('token', json.token);",
                  "pm.collectionVariables.set('primaryUserId', String(json.user.id));",
                  "pm.collectionVariables.set('primaryWalletId', String(json.wallet.id));",
                  "",
                  "pm.test('Register response returns token and wallet', function () {",
                  "  pm.expect(json.message).to.eql('Registration successful');",
                  "  pm.expect(json.token).to.be.a('string');",
                  "  pm.expect(json.user.email).to.eql(pm.collectionVariables.get('primaryEmail'));",
                  "  pm.expect(json.user.phone).to.eql(pm.collectionVariables.get('primaryPhone'));",
                  "  pm.expect(json.wallet.currency).to.eql('NGN');",
                  "});"
                ]
              }
            }
          ],
          "request": {
            "auth": {
              "type": "noauth"
            },
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              },
              {
                "key": "Accept",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"firstName\": \"Smith\",\n  \"lastName\": \"Primary\",\n  \"email\": \"{{primaryEmail}}\",\n  \"phone\": \"{{primaryPhone}}\",\n  \"password\": \"{{primaryPassword}}\"\n}"
            },
