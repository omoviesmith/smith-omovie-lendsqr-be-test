{
  "name": "smith-omovie-lendsqr-be-test",
  "version": "1.0.0",
  "description": "Backend wallet API for the Lendsqr Demo Credit assessment.",
  "main": "dist/server.js",
  "scripts": {
    "dev": "tsx watch src/server.ts",
    "build": "tsc -p tsconfig.json",
    "start": "node dist/server.js",
    "test": "jest --runInBand",
    "lint": "eslint . --ext .ts",
    "format": "prettier --write .",
    "migrate": "tsx ./node_modules/knex/bin/cli.js --knexfile knexfile.ts migrate:latest",
    "migrate:rollback": "tsx ./node_modules/knex/bin/cli.js --knexfile knexfile.ts migrate:rollback",
    "seed": "tsx ./node_modules/knex/bin/cli.js --knexfile knexfile.ts seed:run"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/omoviesmith/smith-omovie-lendsqr-be-test.git"
  },
  "keywords": [],
  "author": "Smith Omovie",
  "license": "MIT",
  "bugs": {
    "url": "https://github.com/omoviesmith/smith-omovie-lendsqr-be-test/issues"
  },
  "homepage": "https://github.com/omoviesmith/smith-omovie-lendsqr-be-test#readme",
  "engines": {
    "node": ">=20.0.0"
  },
  "dependencies": {
    "bcryptjs": "^3.0.3",
    "cors": "^2.8.6",
    "dotenv": "^17.4.2",
    "express": "^5.2.1",
    "helmet": "^8.1.0",
    "jsonwebtoken": "^9.0.3",
    "knex": "^3.2.10",
    "morgan": "^1.10.1",
    "mysql2": "^3.22.3",
    "swagger-ui-express": "^5.0.1",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@types/bcryptjs": "^2.4.6",
    "@types/cors": "^2.8.19",
    "@types/express": "^5.0.6",
    "@types/jest": "^30.0.0",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/morgan": "^1.9.10",
    "@types/node": "^25.6.0",
    "@types/supertest": "^7.2.0",
    "@types/swagger-ui-express": "^4.1.8",
    "@typescript-eslint/eslint-plugin": "^8.59.2",
    "@typescript-eslint/parser": "^8.59.2",
    "eslint": "^10.3.0",
    "jest": "^30.3.0",
    "prettier": "^3.8.3",
    "supertest": "^7.2.2",
    "ts-jest": "^29.4.9",
    "tsx": "^4.21.0",
    "typescript": "^6.0.3"
  }
}
